<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Task</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <%- include('navbar') %>
    <h1>Update Task</h1>

    <form action="/update" method="post">
        <input type="hidden" name="id" value="<%= data.id %>">
        <input type="text" name="title" id="title" value="<%= data.title %>" required placeholder="Title"> <br>
        <textarea name="description" id="description" required placeholder="Description"><%= data.description %></textarea> <br>
        <input type="submit" value="submit">
    </form>

</body>
</html>